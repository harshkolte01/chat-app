{
  "name": "chat-app",
  "version": "0.1.0",
  "private": true,
  "description": "Secure realtime desktop and web chat for private team conversations.",
  "author": "SecretChat",
  "main": "desktop-chat-app/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "realtime:build": "tsc -p realtime-server/tsconfig.json",
    "realtime:start": "node realtime-server/dist/realtime-server/src/index.js",
    "desktop:start": "set ELECTRON_RUN_AS_NODE=&& electron ./desktop-chat-app/main.cjs",
    "desktop:dev": "set ELECTRON_RUN_AS_NODE=&& electron ./desktop-chat-app/main.cjs",
    "dist:win": "electron-builder --win nsis",
    "dist:portable": "electron-builder --win portable",
    "dist:dir": "electron-builder --dir",
    "lint": "eslint",
    "test:socket": "node scripts/socket-realtime-check.mjs",
    "db:reset-data": "node scripts/reset-db-data.mjs",
    "db:create-two-users": "node scripts/create-two-users.mjs",
    "db:create-user": "node scripts/create-user.mjs"
  },
  "build": {
    "appId": "sec-chat.desktop",
    "productName": "SecretChat",
    "copyright": "Copyright © 2026 SecretChat",
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "files": [
      "desktop-chat-app/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "secretchat.ico"
    }
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "dotenv": "^16.6.1",
    "emoji-mart": "^5.6.0",
    "next": "16.1.6",
    "pg": "^8.19.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.4.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
