// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum MessageType {
  TEXT
  IMAGE
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum CallMode {
  AUDIO
  VIDEO
}

enum CallStatus {
  RINGING
  ACTIVE
  REJECTED
  MISSED
  CANCELED
  ENDED
  FAILED
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique
  email        String   @unique
  passwordHash String
  pinHash      String?
  pinVersion   Int      @default(0)
  pinUpdatedAt DateTime?
  createdAt    DateTime @default(now())

  // Conversations where this user is stored as "A" (lexicographically smaller UUID)
  conversationsAsA Conversation[]    @relation("ConversationUserA")
  // Conversations where this user is stored as "B" (lexicographically larger UUID)
  conversationsAsB Conversation[]    @relation("ConversationUserB")

  messages          Message[]
  userConversations UserConversation[]
  outgoingCalls     CallSession[] @relation("CallSessionCaller")
  incomingCalls     CallSession[] @relation("CallSessionCallee")
  endedCalls        CallSession[] @relation("CallSessionEndedBy")
}

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  // Normalisation rule (enforced at app layer before insert):
  //   userAId = min(userIdX, userIdY)   — lexicographic UUID order
  //   userBId = max(userIdX, userIdY)
  // This, combined with @@unique([userAId, userBId]), guarantees exactly
  // one row per pair regardless of who initiates the chat.
  userAId   String   @db.Uuid
  userBId   String   @db.Uuid
  createdAt DateTime @default(now())

  userA             User               @relation("ConversationUserA", fields: [userAId], references: [id])
  userB             User               @relation("ConversationUserB", fields: [userBId], references: [id])
  messages          Message[]
  userConversations UserConversation[]
  calls             CallSession[]

  @@unique([userAId, userBId])
}

model Message {
  id             String        @id @default(uuid()) @db.Uuid
  conversationId String        @db.Uuid
  senderId       String        @db.Uuid
  replyToMessageId String?     @db.Uuid
  type           MessageType   @default(TEXT)
  /// Populated when type = TEXT
  text           String?
  /// S3/MinIO object key; populated when type = IMAGE
  imageKey       String?
  status         MessageStatus @default(SENT)
  createdAt      DateTime      @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  replyToMessage Message?    @relation("MessageReplyThread", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies        Message[]   @relation("MessageReplyThread")
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([replyToMessageId])
}

/// Tracks the last time each participant read a conversation —
/// used for unread-count / read-receipt features.
model UserConversation {
  conversationId String   @db.Uuid
  userId         String   @db.Uuid
  lastReadAt     DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@id([conversationId, userId])
}

model CallSession {
  id             String     @id @default(uuid()) @db.Uuid
  conversationId String     @db.Uuid
  callerId       String     @db.Uuid
  calleeId       String     @db.Uuid
  mode           CallMode
  status         CallStatus @default(RINGING)
  failureReason  String?
  answeredAt     DateTime?
  endedAt        DateTime?
  endedById      String?    @db.Uuid
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  caller       User         @relation("CallSessionCaller", fields: [callerId], references: [id])
  callee       User         @relation("CallSessionCallee", fields: [calleeId], references: [id])
  endedBy      User?        @relation("CallSessionEndedBy", fields: [endedById], references: [id])

  @@index([conversationId, createdAt])
  @@index([conversationId, status, createdAt])
  @@index([callerId, status])
  @@index([calleeId, status])
  @@index([status, createdAt])
}
