{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "..",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["node"]
  },
  "include": [
    "./src/**/*.ts",
    "../lib/auth/constants.ts",
    "../lib/auth/pin.ts",
    "../lib/chat/read-state.ts",
    "../lib/db.ts",
    "../lib/realtime/**/*.ts",
    "../lib/socket/contracts.ts",
    "../lib/socket/server.ts"
  ],
  "exclude": ["../node_modules", "../.next", "../release"]
}
